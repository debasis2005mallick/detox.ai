{
  "manifest_version": 3,
  "name": "Detox.ai",
  "version": "1.0.0",
  "description": "Zero-Trust Privacy Layer for AI. Decouple Identity from Intelligence.",
  "action": {
    "default_title": "Open Detox.ai",
    "default_popup": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*"
  ]
}
